# Pi Portal Configuration
# Copy this file to .env and customize as needed
# All environment variables use the PI_PORTAL_ prefix

# Pi Configuration
# Path to the Pi executable (default: "pi")
PI_PORTAL_PI_EXECUTABLE=pi

# Directory for Pi session storage (default: "data/pi_sessions")
# Can be relative to project root or absolute path
PI_PORTAL_PI_SESSION_DIR=data/pi_sessions

# Server Configuration
# Host to bind the server to (default: "0.0.0.0")
PI_PORTAL_SERVER_HOST=0.0.0.0

# Port to run the server on (default: 8000)
PI_PORTAL_SERVER_PORT=8000

# Enable auto-reload during development (default: false)
PI_PORTAL_SERVER_RELOAD=false
